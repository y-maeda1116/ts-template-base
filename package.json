{
  "name": "ts-template-base",
  "version": "0.0.1",
  "description": "TypeScript template repository for Node.js tool development",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "typescript",
    "template",
    "nodejs"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**",
    "format:check": "prettier --check src/**",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.12.7",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  }
}
